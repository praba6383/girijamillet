{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "Product in the millet store",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the product"
        },
        "name": {
          "type": "string",
          "description": "English name of the product"
        },
        "tamilName": {
          "type": "string",
          "description": "Tamil name of the product"
        },
        "price": {
          "type": "number",
          "description": "Price in INR"
        },
        "weight": {
          "type": "string",
          "description": "Weight of pack (e.g. 250g)"
        },
        "category": {
          "type": "string",
          "description": "Category name"
        },
        "description": {
          "type": "string",
          "description": "Detailed product description"
        },
        "image": {
          "type": "string",
          "description": "Product image source path or base64 data"
        },
        "colorTheme": {
          "type": "string",
          "description": "Color theme class name"
        },
        "ingredients": {
          "type": "array",
          "description": "Ingredients list"
        },
        "benefits": {
          "type": "array",
          "description": "Benefits list"
        },
        "howToUse": {
          "type": "array",
          "description": "Instructions of use list"
        },
        "isNew": {
          "type": "boolean",
          "description": "Is this a newly released product"
        },
        "isPopular": {
          "type": "boolean",
          "description": "Is this a best seller"
        },
        "fssai": {
          "type": "string",
          "description": "FSSAI certification info"
        }
      },
      "required": [
        "id",
        "name",
        "price",
        "weight",
        "category",
        "description",
        "image"
      ]
    }
  },
  "firestore": {
    "products/{productId}": {
      "schema": "Product",
      "description": "Collection of available millet products in the shop"
    }
  }
}
